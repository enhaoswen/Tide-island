#!/bin/bash
# Launcher for Tide Island Quickshell component

# Resolve resources relative to the installed launcher. This keeps system
# installs under /usr and unprivileged installs under ~/.local self-contained.
LAUNCHER_PATH="$(readlink -f "$0")"
INSTALL_PREFIX="$(dirname "$(dirname "$LAUNCHER_PATH")")"
QML_PATH="${TIDE_ISLAND_QML_PATH:-$INSTALL_PREFIX/share/tide-island}"
CONFIG_APP="${TIDE_ISLAND_CONFIG_APP:-$INSTALL_PREFIX/bin/tide-island-config-app}"
QML_MODULE_PATH="$INSTALL_PREFIX/@CMAKE_INSTALL_LIBDIR@/qt6/qml"
SERVICE_NAME="tide-island.service"

export QML_IMPORT_PATH="$QML_MODULE_PATH${QML_IMPORT_PATH:+:$QML_IMPORT_PATH}"
export QUICKSHELL_LYRICS_BACKEND="${QUICKSHELL_LYRICS_BACKEND:-$QML_PATH/bin/lyricsmpris}"
# Quickshell uses jemalloc. Reclaim released Loader/image allocations in the
# background instead of keeping their high-water mark resident indefinitely.
export MALLOC_CONF="${MALLOC_CONF:-narenas:2,background_thread:true,dirty_decay_ms:2000,muzzy_decay_ms:2000}"

if [[ "${SYSTEMD_EXEC_PID:-}" != "$$" ]]; then
  if systemctl --user is-active --quiet "$SERVICE_NAME" \
      || pgrep -u "$(id -u)" -f "/usr/bin/quickshell -p $QML_PATH" >/dev/null; then
    /usr/bin/quickshell ipc --any-display -p "$QML_PATH" call island show >/dev/null 2>&1 || true
    exit 0
  fi
fi

desktop_name=":${XDG_CURRENT_DESKTOP,,}:"
compositor_override="${TIDE_ISLAND_COMPOSITOR,,}"
if [[ "$compositor_override" == "niri" ]] \
    || [[ -z "$compositor_override" && "$desktop_name" == *":niri:"* ]] \
    || [[ -z "$compositor_override" && "$desktop_name" != *":hyprland:"* && -n "${NIRI_SOCKET:-}" ]]; then
  "$CONFIG_APP" --ensure-niri-shortcuts || true
fi

exec /usr/bin/quickshell -p "$QML_PATH" "$@"
