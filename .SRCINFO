pkgbase = tide-island
	pkgdesc = A dynamic island for Hyprland and niri using Quickshell
	pkgver = 1.0.27
	pkgrel = 1
	url = https://github.com/enhaoswen/Tide-island
	install = tide-island.install
	arch = x86_64
	license = GPL-3.0-only
	makedepends = cmake
	depends = qt6-base
	depends = qt6-declarative
	depends = qt6-wayland
	depends = qt6-connectivity
	depends = qt6-svg
	depends = wireplumber
	depends = pipewire
	depends = dbus
	depends = libpulse
	depends = systemd
	depends = brightnessctl
	depends = upower
	depends = bluez
	depends = bluez-utils
	depends = quickshell
	optdepends = hyprland: for Hyprland compositor integration
	optdepends = niri: for niri compositor integration
	optdepends = hyprsunset: for Night Light on Hyprland
	optdepends = gammastep: for Night Light on niri or generic Wayland sessions
	optdepends = cava: for audio visualizer
	optdepends = imagemagick: for wallpaper thumbnails
	optdepends = awww: for applying wallpapers from the wallpaper picker
	optdepends = python-pywal: for generating colors from the selected wallpaper
	optdepends = networkmanager: for wifi control
	optdepends = iwd: for wifi control
	optdepends = swaync: for the Focus do-not-disturb toggle
	optdepends = tlp: for TLP power profile controls
	optdepends = polkit: for applying TLP profiles via pkexec
	optdepends = sudo: alternative for applying TLP profiles
	optdepends = zenity: for Ask-mode TLP password prompts when no Polkit agent is running
	conflicts = tide-island-git
	options = !debug
	options = !strip
	source = tide-island-1.0.27.tar.gz::https://github.com/enhaoswen/Tide-island/archive/refs/tags/1.0.27.tar.gz
	sha256sums = SKIP

pkgname = tide-island
