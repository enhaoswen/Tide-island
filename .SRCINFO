pkgbase = tide-island
	pkgdesc = A dynamic island for Hyprland using Quickshell
	pkgver = 1.0.18
	pkgrel = 1
	url = https://github.com/enhaoswen/Tide-island
	install = tide-island.install
	arch = x86_64
	license = unknown
	makedepends = cmake
	depends = qt6-base
	depends = qt6-declarative
	depends = qt6-wayland
	depends = qt6-connectivity
	depends = qt6-svg
	depends = hyprland
	depends = wireplumber
	depends = pipewire
	depends = dbus
	depends = libpulse
	depends = systemd-libs
	depends = brightnessctl
	depends = hyprsunset
	depends = upower
	depends = bluez
	depends = bluez-utils
	depends = quickshell
	optdepends = cava: for audio visualizer
	optdepends = imagemagick: for wallpaper thumbnails
	optdepends = awww: for applying wallpapers from the wallpaper picker
	optdepends = networkmanager: for wifi control
	optdepends = iwd: for wifi control
	optdepends = swaync: for the Focus do-not-disturb toggle
	optdepends = tlp: for TLP power profile controls
	optdepends = polkit: for applying TLP profiles via pkexec
	optdepends = sudo: alternative for applying TLP profiles
